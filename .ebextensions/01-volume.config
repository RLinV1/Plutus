# Root EBS volume for the EB instance(s). The default (~8 GB) is too small to
# build the API image (torch + chromadb + transformers + embedding model), so
# set it explicitly. Applied to instances launched by the environment.
option_settings:
  aws:autoscaling:launchconfiguration:
    RootVolumeType: gp3
    RootVolumeSize: "10"
