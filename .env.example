# Copy to .env and fill in. Stock data comes from live yfinance by default;
# the AI agent + RAG knowledge library are the added layer on top.

# --- Claude agent (optional) ---
# Add a key to switch the agent from the built-in mock agent to real Claude.
ANTHROPIC_API_KEY=

# --- Mode switches ---
# USE_MOCK_DATA: "0" (default) uses live yfinance data (cached to data/cache).
#                "1" uses deterministic synthetic prices, no network (tests/evals).
USE_MOCK_DATA=0

# USE_MOCK_LLM: "auto" (default) uses the mock agent when ANTHROPIC_API_KEY is
#               empty, real Claude when it is set. Force with "1" or "0".
USE_MOCK_LLM=auto

# --- SEC EDGAR ingest (optional) ---
# EDGAR requires a descriptive User-Agent. Only needed for rag.ingest --edgar.
EDGAR_USER_AGENT=Your Name your.email@example.com

# --- Clerk authentication (optional) ---
# Create a free account at https://clerk.com, add Google OAuth in the dashboard,
# then fill in both keys. Leave empty for local dev (anonymous/shared mode).
CLERK_JWKS_URL=
# Frontend key (starts with pk_test_ or pk_live_):
VITE_CLERK_PUBLISHABLE_KEY=

# --- Infrastructure (optional; docker-compose sets these for you) ---
# Leave REDIS_URL / DATABASE_URL EMPTY for local dev + tests: the cache falls
# back to an in-process dict, the DB no-ops, and RAG uses embedded Chroma — so
# `pytest` and the eval harness stay deterministic and offline.
REDIS_URL=
DATABASE_URL=
# RAG backend: "chroma" (default, embedded) or "pgvector" (hybrid; needs DATABASE_URL).
RAG_BACKEND=chroma
# Cross-encoder reranker after hybrid retrieval (downloads a model on first use).
RAG_RERANK=0
# Postgres credentials (used by the compose postgres service + DATABASE_URL).
POSTGRES_USER=stock
POSTGRES_PASSWORD=stock
POSTGRES_DB=stock
